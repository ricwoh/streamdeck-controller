# Maintainer: Rico <ricwoh@pm.me>
pkgname=streamdeck-controller
pkgver=r5.00d27e7
pkgrel=1
pkgdesc="Elgato Stream Deck GUI-Konfigurator und Controller (Daemon, Spotify Web-API, Multi-Press)"
arch=('x86_64')
url="https://github.com/ricwoh/streamdeck-controller"
license=('MIT')
depends=('python' 'hidapi' 'pyside6' 'python-pillow' 'python-elgato-streamdeck' 'python-requests')
makedepends=('git')
install="$pkgname.install"
source=("streamdeck-controller::git+https://github.com/ricwoh/streamdeck-controller.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/$pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
    cd "$srcdir/$pkgname"

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    local sitedir
    sitedir="$(python -c 'import sysconfig; print(sysconfig.get_path("purelib"))')"
    install -dm755 "$pkgdir$sitedir"
    cp -r streamdeck_controller "$pkgdir$sitedir/streamdeck_controller"
    find "$pkgdir$sitedir" -type d -name __pycache__ -prune -exec rm -rf {} +

    install -dm755 "$pkgdir/usr/share/$pkgname/icons"
    cp -r icons/. "$pkgdir/usr/share/$pkgname/icons/"

    install -Dm755 /dev/stdin "$pkgdir/usr/bin/streamdeck" <<'EOF'
#!/usr/bin/env bash
export STREAMDECK_ICONS_DIR=/usr/share/streamdeck-controller/icons
exec python3 -m streamdeck_controller "$@"
EOF
    ln -s streamdeck "$pkgdir/usr/bin/streamdeck-controller"

    install -Dm644 data/streamdeck-controller.desktop \
        "$pkgdir/usr/share/applications/streamdeck-controller.desktop"

    install -Dm644 data/50-elgato-streamdeck.rules \
        "$pkgdir/usr/lib/udev/rules.d/50-elgato-streamdeck.rules"
}
