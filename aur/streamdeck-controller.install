post_install() {
    udevadm control --reload-rules 2>/dev/null || true
    udevadm trigger 2>/dev/null || true
    echo ""
    echo "  Stream Deck Controller wurde installiert."
    echo "  GUI: streamdeck ui oder App-Menü → Stream Deck Controller"
    echo "  Autostart aktivieren: streamdeck autostart on"
    echo "  Tipp: Stream Deck USB kurz trennen und wieder einstecken."
    echo ""
}

post_upgrade() {
    post_install
}

post_remove() {
    udevadm control --reload-rules 2>/dev/null || true
}
