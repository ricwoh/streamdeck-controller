#!/usr/bin/env bash
# Stream Deck CLI wrapper for source checkouts.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
APP="$SCRIPT_DIR/streamdeck_app.py"
CONFIG="$HOME/.config/streamdeck/config.json"
VENV="${STREAMDECK_VENV:-$HOME/.venv/streamdeck}"
PYTHON="${STREAMDECK_PYTHON:-$VENV/bin/python3}"

run_app() {
  if [[ -x "$PYTHON" ]]; then
    exec "$PYTHON" "$APP" "$@"
  fi
  exec python3 "$APP" "$@"
}

case "${1:-run}" in
  run)
    shift || true
    run_app "$@"
    ;;
  start)
    mkdir -p "$(dirname "$HOME/.streamdeck.log")"
    nohup "$PYTHON" "$APP" > "$HOME/.streamdeck.log" 2>&1 &
    echo "PID: $!"
    ;;
  stop)
    pkill -f "$APP" && echo "Stream Deck gestoppt." || echo "Stream Deck läuft nicht."
    ;;
  restart)
    "$0" stop || true
    sleep 1
    "$0" start
    ;;
  config)
    "${EDITOR:-xdg-open}" "$CONFIG"
    ;;
  list-devices)
    run_app --list-devices
    ;;
  log)
    tail -f "$HOME/.streamdeck.log"
    ;;
  status)
    pgrep -af "$APP" || echo "Gestoppt"
    ;;
  *)
    echo "Verwendung: streamdeck {run|start|stop|restart|config|list-devices|log|status}"
    exit 2
    ;;
esac
