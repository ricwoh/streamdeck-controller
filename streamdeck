#!/usr/bin/env bash
# Stream Deck CLI — dünner Wrapper um das Python-Paket.
# Ohne Argumente wird die Hilfe mit allen Befehlen angezeigt.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
VENV="${STREAMDECK_VENV:-$HOME/.venv/streamdeck}"

if [[ -x "$VENV/bin/python3" ]]; then
  PYTHON="$VENV/bin/python3"
elif [[ -x "$SCRIPT_DIR/.venv/bin/python3" ]]; then
  PYTHON="$SCRIPT_DIR/.venv/bin/python3"
else
  PYTHON="$(command -v python3)"
fi

# Im Source-Checkout liegt das Paket neben diesem Skript
if [[ -d "$SCRIPT_DIR/streamdeck_controller" ]]; then
  export PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}"
fi

exec "$PYTHON" -m streamdeck_controller "$@"
